        </mxCell>
        <mxCell id="4gfk7IVEUvd7JperrWfW-32" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#FFFFFF,#333333);" value="" vertex="1">
          <mxGeometry height="360" width="945" x="-1000" y="980" as="geometry" />
        </mxCell>
        <mxCell id="4gfk7IVEUvd7JperrWfW-27" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;strong&gt;EP1 — &quot;The Secret Forest&quot;&lt;/strong&gt;&lt;br/&gt;T wakes up lost. P (a strange guardian) blocks the exit. T must win the slot machine to escape. P hints that W is with someone called U — the criminal boss." vertex="1">
          <mxGeometry height="40" width="915" x="-980" y="1010" as="geometry" />
        </mxCell>
        <mxCell id="4gfk7IVEUvd7JperrWfW-28" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="EP2 — &quot;Dread&#39;s Trap&quot;&lt;br&gt;T finds D, one of U&#39;s guards. D tricks T into eating a spoiled cake that weakens him and swaps his controls. T must push 3 rocks into holes within 2 minutes to prove himself. D then gives T real food and opens the path forward." vertex="1">
          <mxGeometry height="70" width="910" x="-985" y="1070" as="geometry" />
        </mxCell>
        <mxCell id="4gfk7IVEUvd7JperrWfW-29" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="EP3 — &quot;The Old Shade&quot;&lt;br&gt;T meets S, an old man who knows where U is hiding with W. S lost his keys somewhere in the ruins. T must find them using S&#39;s bulldozer. S opens the final door as thanks." vertex="1">
          <mxGeometry height="30" width="910" x="-985" y="1160" as="geometry" />
        </mxCell>
        <mxCell id="4gfk7IVEUvd7JperrWfW-30" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;strong&gt;EP4 — &quot;Ultim&quot;&lt;/strong&gt;&lt;br/&gt;T finally reaches U, who is holding W. U challenges T to Tic-Tac-Toe — win and take W home, lose 3 times and die. T wins. U lets them go but never explains why he took W. T doesn&#39;t get an answer." vertex="1">
          <mxGeometry height="60" width="910" x="-985" y="1220" as="geometry" />
        </mxCell>
        <mxCell id="4gfk7IVEUvd7JperrWfW-31" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="end" vertex="1">
